{% from "macros/color-row-accent.njk" import colorRowAccent %}

{% macro colorDisplayAccent(colors) %}
  <div x-data="accentSection">
    <div class="flex justify-end mb-2">
      <label
        class="inline-flex items-center gap-2 text-sm text-darkokai-subtext_0 cursor-pointer select-none"
      >
        <span>Show raw value</span>
        <button
          role="switch"
          x-bind:aria-checked="showTrueOklch.toString()"
          x-on:click="showTrueOklch = !showTrueOklch"
          x-bind:class="showTrueOklch ? 'bg-darkokai-default-green' : 'bg-darkokai-surface_1'"
          class="relative inline-flex h-5 w-9 items-center rounded-full transition-colors border-none cursor-pointer"
        >
          <span
            x-bind:class="showTrueOklch ? 'translate-x-5' : 'translate-x-1'"
            class="inline-block h-3 w-3 rounded-full bg-white transition-transform"
          ></span>
        </button>
      </label>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr
            class="border-b border-darkokai-surface_0 text-darkokai-subtext_0 text-sm uppercase tracking-wider"
          >
            <th class="py-2 px-2 font-medium">Color</th>
            <th class="py-2 px-2 font-medium">Name</th>
            <th class="py-2 px-2 text-right font-medium">OKLCH</th>
            <th class="py-2 px-2 text-right font-medium">Hex</th>
            <th class="py-2 px-2 text-right font-medium">RGB</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-darkokai-surface_0/30">
          {% for color in colors %}{{ colorRowAccent(color) }}{% endfor %}
        </tbody>
      </table>
    </div>
  </div>
{% endmacro %}
