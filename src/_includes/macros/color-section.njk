{% macro colorSection(title, startOpen=true) %}
  <div
    x-data="collapsible"
    {% if not startOpen %}data-collapsed{% endif %}
    class="mt-4"
  >
    <button
      x-on:click="toggle"
      class="cursor-pointer bg-transparent border-none p-0 w-full text-left flex items-center gap-2"
    >
      <span
        class="text-darkokai-subtext_0 text-sm transition-transform duration-250"
        x-bind:class="open ? 'rotate-90' : ''"
        >&#9654;</span
      >
      <h3 class="text-darkokai-text font-semibold text-xl inline">
        {{ title }}
      </h3>
    </button>
    <div
      x-show="open"
      x-collapse:enter.duration.500ms
      x-collapse:leave.duration.250ms
    >
      {{ caller() }}
    </div>
  </div>
{% endmacro %}
