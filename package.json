{
  "name": "darkokai-palette",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "NODE_ENV=production eleventy",
    "check:check": "oxfmt --check . && prettier --check \"src/**/*.njk\"",
    "dev": "eleventy --serve",
    "format": "oxfmt --write . && prettier --write \"src/**/*.njk\"",
    "package": "pnpm run build && tar cf - -C _site . | brotli -o _site.tar.br",
    "preview": "serve _site"
  },
  "dependencies": {
    "@alpinejs/collapse": "^3.15.12",
    "alpinejs": "^3.15.12"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-plugin-vite": "^8.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "culori": "^4.0.2",
    "eslint": "^10.4.0",
    "oxfmt": "^0.50.0",
    "prettier": "^3.8.0",
    "prettier-plugin-jinja-template": "^2.2.0",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.0",
    "vite": "^8.0.13"
  }
}
